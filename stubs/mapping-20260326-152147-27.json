{
  "request" : {
    "urlPathPattern" : "/pet/([^/]+)",
    "method" : "POST",
    "queryParameters" : {
      "status" : {
        "equalTo" : "string"
      }
    }
  },
  "response" : {
    "status" : 400,
    "jsonBody" : {
      "code" : 400,
      "type" : "client_error",
      "message" : "Invalid input"
    },
    "headers" : {
      "Content-Type" : "application/json"
    }
  },
  "priority" : 5
}