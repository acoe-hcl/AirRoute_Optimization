      "ignoreArrayOrder" : true,
      "ignoreExtraElements" : true
    } ]
  },
  "response" : {
    "status" : 422,
    "jsonBody" : {
      "code" : 422,
      "type" : "client_error",
      "message" : "Validation exception"
    },
    "headers" : {
      "Content-Type" : "application/json"
    }
  },
  "priority" : 5
}