{
  "request" : {
    "urlPathPattern" : "/pet/([^/]+)/uploadImage",
    "method" : "POST",
    "queryParameters" : {
      "additionalMetadata" : {
        "equalTo" : "string"
      }
    },
    "bodyPatterns" : [ {
      "equalToJson" : "string",
      "ignoreArrayOrder" : true,
      "ignoreExtraElements" : true
    } ]
  },
  "response" : {
    "status" : 200
  },
  "priority" : 5
}